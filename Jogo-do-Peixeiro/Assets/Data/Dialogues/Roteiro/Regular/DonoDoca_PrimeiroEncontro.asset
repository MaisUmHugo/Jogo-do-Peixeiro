%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6cd0e0d0a8b441019c8d3e5a2155f101, type: 3}
  m_Name: DonoDoca_PrimeiroEncontro
  m_EditorClassIdentifier: 
  dialogueId: dono_doca_primeiro_encontro
  description: "Primeiro diálogo com o Dono do Porto."
  lines:
  - speakerName: "Marina"
    sentence: "Opa, bom dia, senhor. Tudo bem?"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Dono do Porto"
    sentence: "Uma cara nova nessa ilhazinha? Raridade hoje em dia. Do que você precisa, amiga?"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "B-bem, eu acabei me metendo numa enrascada e..."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Dono do Porto"
    sentence: "Você pegou dinheiro do cobrador e agora precisa pescar para pagar a dívida antes que ele pegue de volta tudo que fez, te deixe sem estabelecimento e sem lugar para morar, te forçando a viver no mato da ilha."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Dono do Porto"
    sentence: "Correto?"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Hã... foi bem isso sim."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Dono do Porto"
    sentence: "Acredite, você não é a primeira a abrir uma loja de pesca nessa ilha."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Que... específico."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Dono do Porto"
    sentence: "Bem, já que você está aqui, quer dizer que ele te disse que eu compraria seus peixes. E sim, eu compro."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Sério? Caramba, muito obrigada!"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Dono do Porto"
    sentence: "Não tem de quê, amiga. Se precisar de iscas ou de alguém para melhorar seus equipamentos, pode falar comigo. Ajudo no que puder."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Dono do Porto"
    sentence: "Agora pegue seu barco e comece a pescar, se quiser manter sua loja, claro."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Barco? Mas eu não tenho um barco."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Dono do Porto"
    sentence: "Ué, então como você chegou aqui?"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Táxi."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Dono do Porto"
    sentence: "..."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Dono do Porto"
    sentence: "Eu te empresto meu barco."
    cameraFocusTarget: {fileID: 0}
