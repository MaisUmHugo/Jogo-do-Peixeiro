  dialogueId: cobrador_extra_07
  description: "Fala extra do cobrador."
  lines:
  - speakerName: "Marina"
    sentence: "Me diz, já que você nunca sai dessa cabana, o que você come?"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "Dinheiro e as almas dos inocentes. Agora me paga logo antes que eu pegue a sua."
