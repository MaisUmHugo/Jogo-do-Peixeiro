  m_Script: {fileID: 11500000, guid: 6cd0e0d0a8b441019c8d3e5a2155f101, type: 3}
  m_Name: Cobrador_Extra_03
  m_EditorClassIdentifier: 
  dialogueId: cobrador_extra_03
  description: "Fala extra do cobrador."
  lines:
  - speakerName: "Marina"
    sentence: "Sabe, às vezes acho que você teria mais amigos se não ficasse obrigando pessoas a trabalhar pra te dar dinheiro."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "Caramba, eu nunca pensei nisso. Realmente muda muito meu ponto de vista da vida."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Sério? Quer dizer que eu não preciso mais pagar??"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "Claro que precisa. Eu só quis dizer que eu não preciso de amigos com todo o dinheiro que eu tenho. Agora paga logo, vai."
    cameraFocusTarget: {fileID: 0}
