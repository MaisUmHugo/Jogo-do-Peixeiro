  m_Script: {fileID: 11500000, guid: 6cd0e0d0a8b441019c8d3e5a2155f101, type: 3}
  m_Name: Cobrador_Extra_04
  m_EditorClassIdentifier: 
  dialogueId: cobrador_extra_04
  description: "Fala extra do cobrador."
  lines:
  - speakerName: "Cobrador"
    sentence: "Os peixes dessa ilha são tão estranhos... mas o mercado por eles é surpreendentemente grande."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Por que será?"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "Gente rica compra animais pra mostruário. Se eu me importasse com o que eles fazem, eu não teria dinheiro. Agora, você ia me pagar, não ia?"
    cameraFocusTarget: {fileID: 0}
