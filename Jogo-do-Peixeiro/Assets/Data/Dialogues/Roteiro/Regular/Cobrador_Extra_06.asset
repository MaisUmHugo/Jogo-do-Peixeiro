  dialogueId: cobrador_extra_06
  description: "Fala extra do cobrador."
  lines:
  - speakerName: "Cobrador"
    sentence: "Está com o dinheiro?"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "De certa maneira, sim."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "Você não pode só dizer \"de certa maneira\". Me passa logo o dinheiro!"
    cameraFocusTarget: {fileID: 0}
