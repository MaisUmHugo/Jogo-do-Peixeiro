  m_Script: {fileID: 11500000, guid: 6cd0e0d0a8b441019c8d3e5a2155f101, type: 3}
  m_Name: DonoDoca_Vulcao
  m_EditorClassIdentifier: 
  dialogueId: dono_doca_vulcao
  description: "Diálogo com o Dono do Porto dentro do vulcão."
  lines:
  - speakerName: "Dono do Porto"
    sentence: "Marina! Você chegou bem longe para entrar aqui, hein."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Seu dono! Que bom te ver aqui. Vai ficar mais fácil vender os peixes, hehe."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "... Espera. Mas se eu peguei seu barco, como você chegou aqui?"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Dono do Porto"
    sentence: "Andando."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "... Ok?"
    cameraFocusTarget: {fileID: 0}
