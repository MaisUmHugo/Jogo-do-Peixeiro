%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6cd0e0d0a8b441019c8d3e5a2155f101, type: 3}
  m_Name: 02_Intro_Cobrador_Cabana
  m_EditorClassIdentifier: 
  dialogueId: intro_cobrador_cabana
  description: "Cutscene inicial, parte 2. Marina fala com o cobrador e a câmera aponta para a doca."
  lines:
  - speakerName: "Marina"
    sentence: "OPA, COBRADOR, TU TÁ AÍ, MANO??"
    cameraFocusTarget: {fileID: 0}
  - speakerName: ""
    sentence: "..."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Às vezes ele saiu pra comer algo. Vou ver se-"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "Opa, opa. Perdão pela demora, eu estava... ocupado."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Ah, tá. Com o quê? Fazendo suas coisas misteriosas de cobrador?"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "De certa forma, mas isso não importa."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "Mas então, o que achou da loja? Fiz questão de pegar apenas a madeira de maior qualidade para o acabamento."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Ficou supimpa, hein. Poderia morar lá e ficaria de boa."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "Mas você não mora lá? Pediu pra eu colocar uma cama e tudo."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Claro, uai. Onde mais eu moraria?"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "... Quer saber? Eu não vou perguntar."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "De qualquer maneira, ainda temos um último assunto a conversar antes de nosso contrato acabar, que obviamente é-"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Um valeu e um obrigado? Poxa, muito obrigada, né? Hahaha."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "... O pagamento, Marina. Estou falando do quanto você me deve."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Oh... esqueci dessa parte, hehe..."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "Bem, a quantia que você me deve é mais ou menos 1100 moedas."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "1100?? EU MAL FAÇO 100 EM UM MÊS!"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "É sério? Que pena. Esse foi o custo. Então, ou você paga, ou diz adeus para sua lojinha preciosa."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "M-mas... eu não tenho como pagar..."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "Olha, a gente pode fazer um trato. Você vai me pagando em partes e eu não pego a sua loja, mas eu quero toda a dívida paga em 5 dias. Me ouviu?"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "C-claro! Mas eu não sei como eu conseguiria o dinheiro. A venda dos peixes só começa no fim do mês, eu pesco mais agora pra guardar..."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "Tá vendo a doca lá? Ouvi dizer que o dono daquele lugar compra peixes. Você é uma pescadora, não é? Então começa a pescar logo."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "O-ok! Obrigada!"
    cameraFocusTarget: {fileID: 0}
