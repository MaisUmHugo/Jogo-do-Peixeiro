  m_Script: {fileID: 11500000, guid: 6cd0e0d0a8b441019c8d3e5a2155f101, type: 3}
  m_Name: 01_Intro_Marina_Loja
  m_EditorClassIdentifier: 
  dialogueId: intro_marina_loja
  description: "Cutscene inicial, parte 1. Tela escura clareia com Marina em frente à loja."
  lines:
  - speakerName: "Marina"
    sentence: "Finalmente arrumei minhas coisas. Cheguei à ilha mó cansada, mas tudo valeu a pena. A loja tá prontinha, melhor do que eu imaginava também! E quase nem precisei gastar para montar ela, hehe."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Opa, verdade. O cobrador me chamou para a cabana dele. Melhor ir lá checar."
    cameraFocusTarget: {fileID: 0}
