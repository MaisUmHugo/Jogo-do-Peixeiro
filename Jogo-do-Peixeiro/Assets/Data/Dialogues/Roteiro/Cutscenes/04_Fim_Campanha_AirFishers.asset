%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6cd0e0d0a8b441019c8d3e5a2155f101, type: 3}
  m_Name: 04_Fim_Campanha_AirFishers
  m_EditorClassIdentifier: 
  dialogueId: fim_campanha_air_fishers
  description: "Cutscene final, parte 2. O cobrador revela a dívida dos Air Fishers e abre o modo sem fim."
  lines:
  - speakerName: "Marina"
    sentence: "Por que você me chamou aqui de novo, cobrador? Eu já paguei a loja, não paguei?"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "De fato, você pagou a loja, Marina. Mas acho que se esqueceu dos Air Fishers que comprou com o meu dinheiro..."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Oooh, aqueles tênis superlegais, né? Eles são mó estilosos, hehe."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "Tão estilosos que você... se recusa a usar?"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Claro, uai. Não quero estragar eles!"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "Bem, isso não importa muito. Por acaso você viu o preço deles?"
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "Claro, 100 moedas. Isso daí eu já tenho guardado."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "... Eram 100 milhões de moedas, Marina."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "..............."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Cobrador"
    sentence: "Recomendo que você volte a pescar, a não ser que não queira mais esses tênis."
    cameraFocusTarget: {fileID: 0}
  - speakerName: "Marina"
    sentence: "EU PAGO! EU PAGO! TUDO MENOS ISSO, POR FAVOR!"
    cameraFocusTarget: {fileID: 0}
